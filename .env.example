# ============================================================
# Odoo Monitor — Variables de entorno
# Copiar a .env y completar valores reales
# ============================================================

# --- App ---
APP_NAME=odoo-monitor
APP_ENV=production           # production | development | test
DEBUG=false
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- Seguridad ---
# Generar con: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_generate_fernet_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Base de datos ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=odoo_monitor
POSTGRES_USER=odoo_monitor
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://odoo_monitor:changeme_strong_password@postgres:5432/odoo_monitor
DATABASE_URL_SYNC=postgresql+psycopg2://odoo_monitor:changeme_strong_password@postgres:5432/odoo_monitor

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- CORS ---
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# --- Admin inicial (seed) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password
ADMIN_USERNAME=admin

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID default por usuario

# --- Métricas ---
DEFAULT_MONITORING_INTERVAL=60    # segundos entre recolecciones por servidor
METRIC_RETENTION_DAYS=90          # días de retención de métricas históricas
MAX_CONCURRENT_SSH=10             # máx conexiones SSH simultáneas
SSH_TIMEOUT=10                    # timeout en segundos para conexiones SSH

# --- Rate limiting ---
RATE_LIMIT_LOGIN=5/minute         # intentos de login por IP

# --- Frontend (build time) ---
VITE_API_BASE_URL=http://localhost/api/v1
VITE_WS_BASE_URL=ws://localhost/ws
